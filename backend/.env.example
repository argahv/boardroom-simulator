OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_HTTP_REFERRER=http://localhost:3000
OPENROUTER_APP_TITLE=Boardroom Simulator
MAX_TURNS=20

# Database — set DATABASE_TYPE=postgres and fill PG vars to switch
DATABASE_TYPE=sqlite
SQLITE_PATH=./data/boardroom.db

# Tavily API key for persona web research (growth system)
TAVILY_API_KEY=

# Postgres (only needed when DATABASE_TYPE=postgres)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DATABASE=boardroom

